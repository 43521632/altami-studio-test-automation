# Шаблон окружения. Скопируйте в .env и заполните под свою машину:
#
#   cp .env.example .env
#
# Сам .env под .gitignore — реальные пароли в репозиторий не попадают.

# Настройки логирования
LOG_LEVEL=INFO

# Настройки QMP
QMP_TIMEOUT=30
QMP_RETRIES=3

# Настройки тестов
TEST_TIMEOUT=60
PARALLEL_TESTS=false

# Пути к конфигурациям
VMS_CONFIG_PATH=config/vms_config.yaml

# =============================================================================
# Учётные данные для входа в гостевые ОС
# =============================================================================
# Без них автологин упадёт с сообщением, какую переменную заполнить.
# Имя переменной: <VM_ID>_LOGIN_PASSWORD, где VM_ID — ключ из vms_config.yaml.
# Для новой ВМ с ключом, скажем, `debian` переменная будет DEBIAN_LOGIN_PASSWORD.
WINDOWS_LOGIN_PASSWORD=
ASTRA_LOGIN_PASSWORD=

# Имя пользователя обычно берётся из vms_config.yaml, но при необходимости
# перекрывается так же:
# WINDOWS_LOGIN_USER=
# ASTRA_LOGIN_USER=
